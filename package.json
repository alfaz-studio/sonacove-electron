{
  "name": "sonacove-meets",
  "productName": "Sonacove Meets",
  "author": "Alfaz Studio",
  "version": "2025.15.99",
  "description": "Sonacove Meeting App",
  "main": "./build/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/alfaz-studio/sonacove-electron.git"
  },
  "scripts": {
    "start": "webpack --config ./webpack.main.js --mode development && electron .",
    "start:prod": "npm run build && npx electron-builder --dir",
    "clean": "rm -rf node_modules build dist",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "build": "webpack --config ./webpack.main.js --mode production",
    "dist": "npm run build && electron-builder",
    "postinstall": "patch-package"
  },
  "build": {
    "appId": "com.sonacove.meet",
    "productName": "Sonacove Meets",
    "publish": [
      {
        "provider": "github",
        "owner": "alfaz-studio",
        "repo": "sonacove-electron"
      }
    ],
    "files": [
      "build/**/*",
      "resources/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "protocols": [
      {
        "name": "Sonacove Meet Protocol",
        "schemes": [
          "sonacove"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.video-conferencing",
      "hardenedRuntime": true,
      "entitlements": "resources/entitlements.mac.plist",
      "artifactName": "${productName}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "extendInfo": {
        "NSCameraUsageDescription": "Sonacove requires access to your camera for meetings.",
        "NSMicrophoneUsageDescription": "Sonacove requires access to your microphone for meetings.",
        "NSScreenCaptureUsageDescription": "Sonacove requires access to record your screen for sharing.",
        "NSAppleEventsUsageDescription": "Sonacove requires scripting access to control other applications."
      }
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico",
      "artifactName": "Sonacove-Meets-Setup.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico"
    },
    "afterPack": "sign.js",
    "afterAllArtifactBuild": "sign.js",
    "directories": {
      "buildResources": "resources"
    }
  },
  "dependencies": {
    "@jitsi/electron-sdk": "9.0.7",
    "electron-context-menu": "^2.5.0",
    "electron-is-dev": "^1.2.0",
    "electron-log": "^5.0.0",
    "electron-reload": "^1.5.0",
    "electron-updater": "6.6.2",
    "electron-window-state": "^5.0.3",
    "posthog-node": "^4.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.17.8",
    "@babel/eslint-parser": "^7.17.0",
    "@jitsi/eslint-config": "^6.0.4",
    "copy-webpack-plugin": "^14.0.0",
    "electron": "40.3.0",
    "electron-builder": "26.0.12",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsdoc": "^50.6.1",
    "patch-package": "8.0.1",
    "rcedit": "^5.0.2",
    "webpack": "^5.94.0",
    "webpack-cli": "^4.9.2"
  }
}
